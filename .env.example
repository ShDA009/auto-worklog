# === EWS Configuration ===
EWS_URL=https://company.example.com/EWS/Exchange.asmx
EWS_USERNAME=you@example.com
EWS_PASSWORD=replace_me
EWS_IGNORED_MEETINGS=занят,обед

# === Jira Configuration ===
JIRA_BASE_URL=https://your-jira.example.com
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace_me

DEFAULT_ISSUE=YOU_PROJECT-1234
WORKDAY_HOURS=8
IS_MANAGER=false
MANAGER_ACTIVITY_COMMENT=Координация и синхронизация задач

JIRA_IGNORED_STATUSES=Новый
JIRA_DAY_CLOSE_STATUSES=Закрыт,Closed,Отменен,Отменён,"Включен в релиз",Отложено
JIRA_JQL_TEMPLATE=project = YOU_PROJECT AND (status NOT IN (${JIRA_IGNORED_STATUSES}) AND issuetype NOT IN (Epic) AND ((assignee = currentUser() AND status NOT IN (${JIRA_DAY_CLOSE_STATUSES})) OR	(assignee WAS currentUser() AND updated >= "%s")) OR reporter = currentUser() AND updated >= "%s") 